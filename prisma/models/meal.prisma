model CatalogFood {
  id       String   @id @default(uuid())
  name     String
  calories Decimal?
  protein  Decimal?
  carbs    Decimal?
  fat      Decimal?

  mealItems              MealItem[]
  preferenceRestrictions PreferenceRestriction[]

  @@map("catalog_foods")
}

model Meal {
  id        String    @id @default(uuid())
  title     String
  notes     String?
  type      MealType
  mood      Int
  energy    Int
  digestion Int
  foodTime  DateTime  @map("food_time")
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  userId String  @db.Uuid
  user   Profile @relation(fields: [userId], references: [id])

  items MealItem[]

  @@map("meals")
}

model MealItem {
  id            String  @id @default(uuid())
  mealId        String // Foreign
  catalogFoodId String // Foreign
  quantity      Decimal
  unit          String

  meal        Meal        @relation(fields: [mealId], references: [id], onDelete: Cascade)
  catalogFood CatalogFood @relation(fields: [catalogFoodId], references: [id])

  @@unique([mealId, catalogFoodId])
  @@map("meal_items")
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  OTHER
}

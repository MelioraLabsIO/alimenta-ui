model Meal {
  id        String   @id @default(uuid())
  title     String
  notes     String?
  type      MealType
  mood      Int
  energy    Int
  digestion Int
  foodTime  DateTime @map("food_timee")
  createdAt DateTime @map("created_at") @default(now())
  updatedAt DateTime @map("updated_at") @updatedAt
  foodItem Food[]

  @@map("meals")
}

model Food {
  id       String  @id @default(uuid())
  name     String
  quantity Decimal
  unit     String
  foodId   String @map("food_id")
  food     Meal    @relation(fields: [foodId], references: [id])

  @@map("foods")
}

enum MealType {
  MEAL
  BREAKFAST
  DINNER
  SNACK
  OTHER
}
